@{
    ViewData["Title"] = "Cadastro";
}

<div class="text-center">
    <h2>Cadastro de Usuario</h2>

    @if (ViewData["RegisterOk"] is string registerOk)
    {
        <p class="text-success">@registerOk</p>
    }

    @if (ViewData["RegisterError"] is string registerError)
    {
        <p class="text-danger">@registerError</p>
    }

    <form asp-controller="Home" asp-action="Register" method="post">
        @Html.AntiForgeryToken()

        <label for="username">Username:</label>
        <input type="text" id="username" name="username" value="@ViewData["SanitizedUsername"]">
        @Html.ValidationMessage("username", null, new { @class = "text-danger" })

        <label for="email">Email:</label>
        <input type="email" id="email" name="email" value="@ViewData["SanitizedEmail"]">
        @Html.ValidationMessage("email", null, new { @class = "text-danger" })

        <label for="password">Password:</label>
        <input type="password" id="password" name="password">
        @Html.ValidationMessage("password", null, new { @class = "text-danger" })

        <label for="confirmPassword">Confirm Password:</label>
        <input type="password" id="confirmPassword" name="confirmPassword">
        @Html.ValidationMessage("confirmPassword", null, new { @class = "text-danger" })

        <button type="submit">Cadastrar</button>
    </form>
</div>
